  <script>
    // INFO-SISÄLLÖT JA TOIMINNOT
    const infoContent = {
      section1: "❗️ Prosessiohje: TYM-asiakkuus voi alkaa heti työttömyyden alkaessa. Työllisyysasiantuntija tekee kartoituspyynnön Kelaan (Eija Lankinen) ja vie tiedot TYPPI-järjestelmään.",
      section2: "❗️ Aikataulu: PTA tehdään esim. puhelimitse ENNEN varsinaista TYM-päivää. PTA on lukittava TYPPIssä ennen Moty-suunnitelman aloittamista.",
      section4: "❗️ TYM-kriteeristö: Asiakkaan on oltava menossa kohti työllistymistä. Arvioi miksi tarvitaan monialaista yhteistyötä (HVA+Kela+Työllisyys) vs. pelkkä konsultaatio.",
      section5: "❗️ Vaikuttavuus: Älä listaa vain nimiä. Kirjaa missä, milloin, mitä teki ja mikä oli palaute/suositus jatkon kannalta.",
      section8: "❗️ Tavoitteenasettelu: Kirjaa vahvuudet ja työllistymisen esteet rehellisesti. Osaamisen puutteet ovat keskeinen signaali.",
      section12: "❗️ Pakollinen toimenpide: Jokainen TYM-asiakas tulee ohjata työttömien terveystarkastukseen!",
      section16: "❗️ KUTY-vaatimukset: Kirjaa: 1) Tavoite/paikka, 2) Kesto per pv/vko, 3) Alkamisaika/pituus, 4) Tuki/ohjaus, 5) Ohella tarjottava sote-tuki.",
      section18: "❗️ Kela-rooli: Hyödynnä Kelan työkykyneuvojia, jos sairauspäiväraha-aika täyttyy tai eläkeselvittely on käynnissä.",
      section20: "❗️ Konkretia: Aseta realistiset tavoitteet seuraavalle 3-6 kuukaudelle. 'Kuka tekee, mitä ja milloin?'",
      section21: "❗️ Päättäminen: Asiakkuus päätetään verkoston yhteisellä päätöksellä (TYPPI-tiedote). Vältä 'Muu syy' -luokitusta ilman perusteluja."
    };

    let currentInfoId = "";

    function showInfo(id, titleText) {
      currentInfoId = id;
      document.getElementById('infoTitle').textContent = "Ohjeet: " + titleText;
      document.getElementById('infoText').textContent = infoContent[id] || "Ei asetettua ohjeistusta tälle osiolle. Klikkaa kynää muokataksesi.";
      document.getElementById('infoDisplayView').classList.remove('hidden');
      document.getElementById('infoEditView').classList.add('hidden');
      document.getElementById('infoModal').style.display = 'flex';
    }

    function enableInfoEdit() {
      document.getElementById('infoDisplayView').classList.add('hidden');
      document.getElementById('infoEditView').classList.remove('hidden');
      document.getElementById('infoEditArea').value = infoContent[currentInfoId] || "";
    }

    function saveInfoEdit() {
      const newVal = document.getElementById('infoEditArea').value;
      infoContent[currentInfoId] = newVal;
      document.getElementById('infoText').textContent = newVal;
      document.getElementById('infoDisplayView').classList.remove('hidden');
      document.getElementById('infoEditView').classList.add('hidden');
      
      const trigger = document.getElementById('trigger-' + currentInfoId);
