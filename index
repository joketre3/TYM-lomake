    function escapeHtml(value) {
      return (value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getValue(id) {
      const el = document.getElementById(id);
      if (!el) return '';
      if (el.type === 'checkbox') return el.checked ? 'Kyllä' : '';
      return (el.value || '').trim();
    }

    function getFieldValue(field) {
      if (typeof field.getter === 'function') {
        return (field.getter() || '').trim();
      }
      return getValue(field.id);
    }

    function checkedValues() {
      const values = [];
      if (document.getElementById('luonneTilapainen').checked) values.push('Tilapäinen');
      if (document.getElementById('luonneToistuva').checked) values.push('Toistuva');
      if (document.getElementById('luonnePitkaaikainen').checked) values.push('Pitkäaikainen');
      return values;
    }

    function autosizeTextarea(el) {
      if (!el) return;
      el.style.height = 'auto';
      el.style.height = Math.max(el.scrollHeight, 70) + 'px';
    }

    function setActiveField(el) {
      activeField = el;
      const labelText = el && el.id ? (document.querySelector('label[for="' + el.id + '"]')?.innerText || el.id) : 'ei valittuna';
      document.getElementById('activeFieldName').textContent = labelText;
    }

    function renderPhraseButtons() {
      const category = document.getElementById('phraseCategory').value;
      const container = document.getElementById('phraseButtons');
      container.innerHTML = '';
      (phraseTemplates[category] || []).forEach(function(item) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.innerHTML = '<strong>' + escapeHtml(item.label) + '</strong><br>' + escapeHtml(item.text);
        btn.addEventListener('click', function() {
          insertPhrase(item.text);
        });
        container.appendChild(btn);
      });
    }

    function insertPhrase(text) {
      if (!activeField || activeField.readOnly) {
        alert('Klikkaa ensin kenttää, johon haluat lisätä fraasipohjan.');
        return;
      }
      const current = activeField.value || '';
      const start = typeof activeField.selectionStart === 'number' ? activeField.selectionStart : current.length;
      const end = typeof activeField.selectionEnd === 'number' ? activeField.selectionEnd : current.length;
      const before = current.slice(0, start);
      const after = current.slice(end);
      const prefix = before && !before.endsWith('\n') ? '\n' : '';
      const suffix = after && !after.startsWith('\n') ? '\n' : '';
      const insertText = prefix + text + suffix;
      activeField.value = before + insertText + after;
      activeField.focus();
      if (typeof activeField.selectionStart === 'number') {
        const pos = before.length + insertText.length;
        activeField.setSelectionRange(pos, pos);
      }
      if (activeField.tagName === 'TEXTAREA') autosizeTextarea(activeField);
      updateFilledView();
    }

    function isSectionVisibleByRule(def) {
      if (def.tymOnly && !document.getElementById('tymToggle').checked) return false;
      return true;
    }

    function isSectionFilled(def) {
      return def.fields.some(function(field) {
        return getFieldValue(field) !== '';
      });
    }

    function updateFilledView() {
      const showOnlyFilled = document.getElementById('filledOnlyToggle').checked;
      sectionDefinitions.forEach(function(def) {
        const sectionEl = document.getElementById(def.id);
        const tocLink = document.querySelector('[data-toc="' + def.id + '"]');
        const visibleByRule = isSectionVisibleByRule(def);
        const filled = isSectionFilled(def);
        const shouldShow = visibleByRule && (!showOnlyFilled || filled);
        sectionEl.classList.toggle('hidden-section', !shouldShow);
        if (tocLink) tocLink.classList.toggle('hidden-section', !shouldShow);
      });
      highlightCurrentToc();
    }

    function openSection(id) {
      const section = document.getElementById(id);
      if (!section) return;
      section.open = true;
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      highlightCurrentToc(id);
    }

    function openAllSections() {
      document.querySelectorAll('details.topic').forEach(function(section) {
        if (!section.classList.contains('hidden-section')) section.open = true;
      });
    }

    function closeAllSections() {
      document.querySelectorAll('details.topic').forEach(function(section) {
        if (!section.classList.contains('hidden-section')) section.open = false;
      });
    }

    function highlightCurrentToc(forcedId) {
      const links = document.querySelectorAll('.toc-link');
      links.forEach(function(link) { link.classList.remove('active'); });
      const targetId = forcedId || getCurrentSectionId();
      if (!targetId) return;
      const activeLink = document.querySelector('.toc-link[data-toc="' + targetId + '"]');
      if (activeLink && !activeLink.classList.contains('hidden-section')) {
        activeLink.classList.add('active');
      }
    }

    function getCurrentSectionId() {
      const visibleSections = Array.from(document.querySelectorAll('details.topic')).filter(function(section) {
        return !section.classList.contains('hidden-section');
      });
      let current = visibleSections[0]?.id || '';
      visibleSections.forEach(function(section) {
        const rect = section.getBoundingClientRect();
        if (rect.top <= 140) current = section.id;
      });
      return current;
    }

    function buildSectionLines(def) {
      const lines = [];
      def.fields.forEach(function(field) {
        const value = getFieldValue(field);
        if (!value) return;
        lines.push(field.label + ': ' + value);
      });
      return lines;
    }

    function generateOutput() {
      const outputParts = [];
      const previewParts = [];

      outputParts.push('TYÖIKÄISTEN PALVELUTARPEEN ARVIO / MONIALAINEN PALVELUTARPEEN ARVIO');
      outputParts.push('');

      previewParts.push('<h1>Työikäisten palvelutarpeen arvio / Monialainen palvelutarpeen arvio</h1>');

      sectionDefinitions.forEach(function(def) {
        if (!isSectionVisibleByRule(def)) return;
        const lines = buildSectionLines(def);
        if (!lines.length) return;

        outputParts.push(def.title);
        outputParts.push(lines.join('\n'));
        outputParts.push('');

        previewParts.push('<h2>' + escapeHtml(def.title) + '</h2>');
        lines.forEach(function(line) {
          previewParts.push('<p>' + escapeHtml(line) + '</p>');
        });
      });

      const outputText = outputParts.join('\n').trim();
      document.getElementById('outputText').value = outputText;
      autosizeTextarea(document.getElementById('outputText'));

      const preview = document.getElementById('documentPreview');
      if (previewParts.length === 1) {
        preview.innerHTML = '<h1>Työikäisten palvelutarpeen arvio / Monialainen palvelutarpeen arvio</h1><p class="placeholder">Täytä lomake ja paina “Päivitä valmis asiakirjateksti”. Asiakirjan esikatselu muodostuu tähän Word-tyyliselle sivulle.</p>';
      } else {
        preview.innerHTML = previewParts.join('');
      }
    }

    async function copyFinalText() {
      generateOutput();
      const text = document.getElementById('outputText').value;
      if (!text) {
        alert('Asiakirjateksti on vielä tyhjä. Täytä vähintään yksi kenttä.');
        return;
      }
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
        } else {
          const output = document.getElementById('outputText');
          output.select();
          output.setSelectionRange(0, 999999);
          document.execCommand('copy');
        }
        alert('Valmis asiakirjateksti kopioitu leikepöydälle.');
      } catch (err) {
        alert('Automaattinen kopiointi ei onnistunut. Voit silti kopioida tekstin käsin valmis asiakirjateksti -kentästä.');
      }
    }

    function clearForm() {
      const ok = confirm('Tyhjennetäänkö koko lomake?');
      if (!ok) return;
      document.getElementById('ptaForm').reset();
      document.getElementById('outputText').value = '';
      document.getElementById('documentPreview').innerHTML = '<h1>Työikäisten palvelutarpeen arvio / Monialainen palvelutarpeen arvio</h1><p class="placeholder">Täytä lomake ja paina “Päivitä valmis asiakirjateksti”. Asiakirjan esikatselu muodostuu tähän Word-tyyliselle sivulle.</p>';
      document.querySelectorAll('textarea').forEach(function(el) { autosizeTextarea(el); });
      document.querySelectorAll('details.topic').forEach(function(section) { section.open = true; });
      document.getElementById('filledOnlyToggle').checked = false;
      toggleTYM();
      updateFilledView();
      document.getElementById('activeFieldName').textContent = 'ei valittuna';
      activeField = null;
    }

    function toggleTYM() {
      const tymSection = document.getElementById('section18');
      const tocLink = document.querySelector('[data-toc="section18"]');
      const checked = document.getElementById('tymToggle').checked;
      if (!checked) {
        tymSection.open = false;
      }
      if (tocLink) {
        tocLink.classList.toggle('hidden-section', !checked && document.getElementById('filledOnlyToggle').checked === false ? false : false);
      }
      updateFilledView();
    }

    function printDocument() {
      generateOutput();
      setTimeout(function() {
        window.print();
      }, 80);
    }

    document.addEventListener('scroll', function() {
      highlightCurrentToc();
    }, { passive: true });

    document.addEventListener('DOMContentLoaded', function() {
      renderPhraseButtons();
      document.querySelectorAll('textarea').forEach(function(el) {
        autosizeTextarea(el);
        el.addEventListener('input', function() {
          autosizeTextarea(el);
          if (document.getElementById('filledOnlyToggle').checked) updateFilledView();
        });
        el.addEventListener('focus', function() { setActiveField(el); });
      });
      document.querySelectorAll('input[type="text"], input[type="date"], select').forEach(function(el) {
        el.addEventListener('focus', function() { setActiveField(el); });
        el.addEventListener('input', function() {
          if (document.getElementById('filledOnlyToggle').checked) updateFilledView();
        });
        el.addEventListener('change', function() {
          if (document.getElementById('filledOnlyToggle').checked) updateFilledView();
        });
      });
      document.querySelectorAll('input[type="checkbox"]').forEach(function(el) {
        el.addEventListener('change', function() {
          if (document.getElementById('filledOnlyToggle').checked) updateFilledView();
        });
      });
      toggleTYM();
      updateFilledView();
      generateOutput();
      highlightCurrentToc('section1');
    });
